{
  "manifest_version": 3,
  "name": "noddle",
  "version": "1.0.0",
  "description": "Removes all the uneccessary features from Toddle.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.toddleapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ]
}